student_records = {}
courses = []
def add_student(name, age, courses):
    if name in student_records:
        print(f"Student {name} already exists.")
    else:
        student_records[name] = {
            "age": age,
            "grades": set(),
            "courses": set(courses)
        }
        print(f"Student '{name}' added successfully.")

def add_grade(name, grade):
    if name in student_records:
        student_records[name]["grades"].add(grade)
        print(f"Grade {grade} added for student '{name}'.")
    else:
        print(f"Student '{name}' not found.")
        return

def is_enrolled(name, course):
    if name in student_records:
        if course in student_records[name]["courses"]:
            return True
        else:
            return False
    else:
        print(f"Student '{name}' not found.")
        return False

def calculate_average_grade(name):
    if name in student_records:
        grades = student_records[name]["grades"]
        if grades: #like if grades exists, at least one grade
            return sum(grades) / len(grades)
        else:
            return 0

    else:
        print(f"Student '{name}' not found.")
        return None

def list_students_by_course(course):
    #get the course and find the names of the students who took it
    new_set = []
    for name, other_info in student_records.items():
        if course in other_info["courses"]:
            new_set.append(name)
    return new_set
       
def filter_top_students(threshold):
    new_list = []
    for name in student_records:
        if calculate_average_grade(name) > threshold:
            new_list.append(name)
    return new_list


